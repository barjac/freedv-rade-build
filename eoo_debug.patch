diff --git a/src/pipeline/eoo_debug.h b/src/pipeline/eoo_debug.h
new file mode 100644
index 00000000..c3ebd9d7
--- /dev/null
+++ b/src/pipeline/eoo_debug.h
@@ -0,0 +1,46 @@
+//=========================================================================
+// Name:            eoo_debug.h
+// Purpose:         Millisecond-precise EOO debug logging to file.
+//                  Written to /tmp/freedv_eoo_debug.log; appends per
+//                  transmission so multiple PTT cycles accumulate.
+//=========================================================================
+
+#ifndef AUDIO_PIPELINE__EOO_DEBUG_H
+#define AUDIO_PIPELINE__EOO_DEBUG_H
+
+#include <cstdio>
+#include <ctime>
+#include <cstdarg>
+
+static inline void eoo_debug(const char* fmt, ...)
+{
+    FILE* f = fopen("/tmp/freedv_eoo_debug.log", "a");
+    if (!f) return;
+
+    struct timespec ts;
+    clock_gettime(CLOCK_REALTIME, &ts);
+    struct tm tm_info;
+    localtime_r(&ts.tv_sec, &tm_info);
+    char timebuf[16];
+    strftime(timebuf, sizeof(timebuf), "%H:%M:%S", &tm_info);
+    fprintf(f, "[%s.%03ld] ", timebuf, ts.tv_nsec / 1000000L);
+
+    va_list args;
+    va_start(args, fmt);
+    vfprintf(f, fmt, args);
+    va_end(args);
+    fprintf(f, "\n");
+    fclose(f);
+}
+
+/* Call once at the start of a new PTT-off sequence to separate log sections. */
+static inline void eoo_debug_begin()
+{
+    FILE* f = fopen("/tmp/freedv_eoo_debug.log", "a");
+    if (!f) return;
+    fprintf(f, "---\n");
+    fclose(f);
+    eoo_debug("=== EOO sequence start ===");
+}
+
+#endif // AUDIO_PIPELINE__EOO_DEBUG_H
