#!/bin/bash
#set -x

# Check we are not root
((UID)) || { echo "ERROR: You must NOT be root user to run $0, use CTRL/d to become $user"; exit 1; }

# Check for missing preload file
if [ -n "$LD_PRELOAD" ] && [ ! -e "$LD_PRELOAD" ]; then
    echo "Warning: LD_PRELOAD points to missing file ($LD_PRELOAD) â€” unsetting."
    unset LD_PRELOAD
fi

# Get user name
user="$(logname 2>/dev/null || echo "$USER")"

# Move into git repository
RUN_DIR="/home/$user/freedv-rade-build"
cd "$RUN_DIR" || { echo "Failed to change to RUN_DIR"; exit 1; }

# Check not already running
exec 8>/tmp/radeupdt.lock
flock -n 8 || { echo "Another instance is already running"; exit 1; }

# Set full path to log
LOGFILE="$RUN_DIR/freedv-rade-update.log"

# Parse flags: strip --restart from args, keep --debug for restart passthrough
RESTARTING=false
DEBUG=false
_args=()
for _arg in "$@"; do
    case "$_arg" in
        --restart) RESTARTING=true ;;
        --debug)   DEBUG=true; _args+=("$_arg") ;;
        *)         _args+=("$_arg") ;;
    esac
done
set -- "${_args[@]}"
unset _arg _args

# Only wipe log & write OS info on fresh run
if ! $RESTARTING; then
    cat /etc/os-release > "$LOGFILE"
    locale >> "$LOGFILE"

    # Append all output from here (logging set up only on fresh run)
    exec > >(tee -a "$LOGFILE")
    exec 2>&1
fi

echo "Script started: $(date)" >> "$LOGFILE"

# Check that this is a 64bit machine
uname -m | grep -q "64" || { echo "ERROR: A 64bit system is needed"; exit 1; }

# Check we are in a git clone
[[ -d "$RUN_DIR/.git" ]] || { echo -e "ERROR: This does not look like a Git repo.\n\n \
Please read the instructions in README.md carefully and try again."; exit 1; }

# Check we have internet and DNS
ping -c3 google.com > /dev/null || { echo "ERROR: Failed to find internet connection or DNS"; exit 1; }

# Self-update check
echo -e "Checking for any updates to this project...\n"
if LC_ALL=C git pull --ff-only | grep -q -v "Already up to date"; then
    echo "Update to freedv-rade-build project found â€” restarting..."
    echo "--- Restarting after update: $(date) ---"
    flock -u 8 || { echo "Failed to release lock"; exit 1; }
    exec "$RUN_DIR/freedv-rade-update" --restart "$@"
fi

echo "Script is up to date"


# Set default branch
default="master"
prbranches=()
pname=""
cname=""

# Get path of base dir in use, defaults to /home/$user
if cat /home/${user}/freedv-rade-build/freedv-rade-build.cfg |grep -v '^[#]'|grep -q "basedir="; then
    basedir=$(cat /home/${user}/freedv-rade-build/freedv-rade-build.cfg|grep -v '^[#]'|grep 'basedir='|cut -d= -f2)
else
    basedir=/home/$user
fi

confirm() {
params=( "$@" )
rval=7
while (( $rval > 6 )); do
    echo -ne "${params[0]} ${params[1]} "
    ans=
    rval=
    read -r ans
    # Get first option if ans is empty
    ans=${ans:-$(echo ${params[1]} | cut -b 2)}
    echo $ans
        case "$ans" in
            [${params[2]}])
                rval=0
                ;;
            [${params[3]}])
                rval=1
                ;;
            [${params[4]}])
                rval=2
                ;;
            [${params[5]}])
                rval=3
                ;;
            [${params[6]}])
                rval=4
                ;;
            [${params[7]}])
                rval=5
                ;;
            [${params[8]}])
                rval=6
                ;;
            *)
                rval=7
                ;;
        esac
done
    return $rval
}

fastupdt() {
cd ${basedir}/freedv-rade/freedv-gui || exit 1

_bi_base=""
_bi_prs=()
_bi_patches=()

# Remove any patched/edited files and sync to origin
echo "Resetting any patches or edits"
git reset --hard HEAD || { echo "ERROR: git reset failed"; exit 1; }
git clean -fd || { echo "ERROR: git clean failed"; exit 1; }

echo "Switching to $default and syncing with origin"
git fetch origin || { echo "ERROR: git fetch failed - check network connection"; exit 1; }
git checkout -B $default origin/$default || { echo "ERROR: failed to reset $default to origin/$default"; exit 1; }
git reset --hard origin/$default || { echo "ERROR: git reset to origin/$default failed"; exit 1; }
_bi_base="${default} @ $(git rev-parse --short HEAD)"

# Ensure git has an identity for merge commits; use a fallback if not configured
if ! git config user.email >/dev/null 2>&1; then
    export GIT_AUTHOR_NAME="freedv-rade-update"
    export GIT_AUTHOR_EMAIL="freedv-rade-update@localhost"
    export GIT_COMMITTER_NAME="freedv-rade-update"
    export GIT_COMMITTER_EMAIL="freedv-rade-update@localhost"
fi

if (( ${#prbranches[@]} == 0 )); then
        echo "Using branch $default"
    else
        # Split the selection into at most one branch/tag entry (the base)
        # and any number of PR-number entries to merge onto that base.
        base_entry=""
        pr_entries=()
        for entry in "${prbranches[@]}"; do
            if [[ "$entry" == pr:* ]]; then
                pr_entries+=("$entry")
            elif [[ "$entry" == *:* ]]; then
                echo "ERROR: Fork branch '$entry' not in upstream. Use a PR number instead."
                exit 1
            else
                if [[ -n "$base_entry" ]]; then
                    echo "ERROR: Only one branch/tag name may be used as the base ('$base_entry' and '$entry' were both given). Use PR numbers for anything else to combine."
                    exit 1
                fi
                base_entry="$entry"
            fi
        done
        base_branch="${base_entry:-$default}"

        if [[ -n "$base_entry" ]]; then
            if git checkout "$base_entry" | grep -q "error:"; then
                echo -e "\nError finding $base_entry - closing.\n"
                exit 1
            fi
            git pull
            _bi_base="${base_entry} @ $(git rev-parse --short HEAD)"
        fi

        if (( ${#pr_entries[@]} == 0 )); then
            # Branch/tag only, nothing to merge onto it.
            echo "Using branch $base_branch"
        else
            # One or more PRs to merge onto the base branch (default, or the named one).
            git checkout -B build/combined "$base_branch" \
                || { echo "ERROR: Could not create build/combined branch"; exit 1; }
            for entry in "${pr_entries[@]}"; do
                prnumber="${entry#pr:}"
                echo "Fetching PR #$prnumber..."
                git fetch origin "+refs/pull/$prnumber/head:pr/$prnumber" \
                    || { echo "ERROR: Failed to fetch PR #$prnumber"; exit 1; }
                prhead=$(git rev-parse --short "pr/$prnumber")
                echo "Merging PR #$prnumber..."
                if ! git merge --no-edit "pr/$prnumber"; then
                    git merge --abort 2>/dev/null
                    echo "ERROR: PR #$prnumber conflicts with existing changes â€” aborting."
                    exit 1
                fi
                echo "PR #$prnumber merged OK"
                _bi_prs+=("pr:${prnumber} @ ${prhead}")
            done
            echo "Using base $base_branch combined with PRs: ${pr_entries[*]}"
        fi
    fi

# Save PR/branch selection for reuse next time
if (( ${#prbranches[@]} > 0 )); then
    printf '%s\n' "${prbranches[@]}" > "/home/${user}/freedv-rade-build/.last-prs"
fi

# Use a specific commit (before applying patches so patches land on top of it)
if (( ${#cname} > 0 )); then
    if ! git checkout --detach $cname; then
        echo "ERROR: Can't find that git#"
        exit 1
    fi
    _bi_base="pinned:$(git rev-parse --short HEAD)"
    _bi_prs=()
fi

# Apply patches if there are any
if (( ${#patches[@]} > 0 )); then
    for patch in "${patches[@]}"; do
    echo "Applying $patch"
    _patch_out=$(patch -p1 --forward < /home/${user}/freedv-rade-build/$patch 2>&1)
    _patch_exit=$?
    echo "$_patch_out"
    if (( _patch_exit != 0 )); then
        if echo "$_patch_out" | grep -q "previously applied\|Skipping patch"; then
            echo "WARNING: $patch appears already applied (included in a merged PR?) â€” skipping."
        else
            echo "$patch failed to apply.  pwd= $(pwd)"
            exit 1
        fi
    else
        _bi_patches+=("${patch#patches/}")
    fi
    done
    git add -A
    git -c user.email="freedv@localhost" -c user.name="FreeDV Update" commit -m "Applied patches: ${patches[*]}"
    printf '%s\n' "${patches[@]}" > "/home/${user}/freedv-rade-build/.last-patches"
fi

cd build_linux || exit 1
if ! [[ -h model19_check3 ]]; then
    ln -s "$(pwd)"/rade_src/model19_check3 model19_check3
fi
if [[ $DEBUG == true ]]; then
    make VERBOSE=1
else
    make
fi
make_exit=$?
if (( make_exit != 0 )); then
    bad_filename=$(grep -o 'Consider deleting local copy of [^ ]*' "$LOGFILE" | tail -1 | awk '{print $NF}')
    if [[ -z "$bad_filename" ]]; then
        bad_file=$(grep -o 'for file: \[.*\]' "$LOGFILE" | tail -1 | sed 's/for file: \[//;s/\]//')
    else
        bad_file=$(find "${basedir}/freedv-rade/freedv-gui/build_linux" -name "$bad_filename" 2>/dev/null | head -1)
    fi
    if [[ -n "$bad_file" && -f "$bad_file" ]]; then
        echo ""
        echo "Checksum error on cached download: $bad_file"
        echo "Deleting and retrying..."
        rm -f "$bad_file"
        if [[ $DEBUG == true ]]; then
            make VERBOSE=1
        else
            make
        fi
        make_exit=$?
    fi
fi
cd || exit 1
if (( make_exit == 0 )); then
    _bi_details="$_bi_base"
    for _pr in "${_bi_prs[@]}"; do
        _bi_details="$_bi_details $_pr"
    done
    if (( ${#_bi_patches[@]} > 0 )); then
        _bi_details="$_bi_details | ${_bi_patches[*]}"
    fi
    write_build_index "$_bi_details"
fi
return $make_exit
}

bye() {
echo -e "\nClosing - Goodbye! :)"
flock -u 8 || { echo "Failed to release lock"; exit 1; }
if [ -n "$SHELL" ]; then
    exec "$SHELL" -i
else
    exec bash -i
fi
}

clearvars () {
fastupdt=
update=
backup=
restore=
switch=
desktop=
}

write_build_index() {
    local details="$1"
    local _idx_file="/home/${user}/freedv-rade-build/.build_index"
    local _build_file="${basedir}/freedv-rade/.build"
    local _next=1
    if [[ -f "$_idx_file" ]] && [[ -s "$_idx_file" ]]; then
        _next=$(( $(awk '{print $1+0}' "$_idx_file" | sort -n | tail -1) + 1 ))
    fi
    local _entry
    _entry="$(printf '%d | %s | %s' "$_next" "$details" "$(date '+%Y-%m-%d %H:%M')")"
    echo "$_entry" >> "$_idx_file"
    echo "$_next" > "$_build_file"
    echo "Build #$_next recorded: $_entry"
}

# Show build details for a given directory (label, dir path)
show_dir_build() {
    local _label="$1"
    local _dir="$2"
    local _idx_file="/home/${user}/freedv-rade-build/.build_index"
    local _build_file="${_dir}/.build"
    if [[ -f "$_build_file" ]]; then
        local _idx
        _idx=$(tr -d '[:space:]' < "$_build_file")
        local _record
        _record=$(grep "^${_idx} |" "$_idx_file" 2>/dev/null)
        if [[ -n "$_record" ]]; then
            local _display="${_record#*| }"
            echo "  ${_label}: build #${_idx}: ${_display//patches\//}"
        else
            echo "  ${_label}: build #${_idx} (no index entry found)"
        fi
    else
        echo "  ${_label}: no build record"
    fi
}

# Show details of the current installed build
showcurrent() {
    local currdir="$(pwd)"
    local _idx_file="/home/${user}/freedv-rade-build/.build_index"
    local _build_file="${basedir}/freedv-rade/.build"
    if [[ -f "$_build_file" ]]; then
        local _idx
        _idx=$(tr -d '[:space:]' < "$_build_file")
        local _record
        _record=$(grep "^${_idx} |" "$_idx_file" 2>/dev/null)
        if [[ -n "$_record" ]]; then
            local _display="${_record#*| }"
            echo -e "\nNOTE: Current build #${_idx}: ${_display//patches\//}\n"
        else
            echo -e "\nNOTE: Build #${_idx} recorded but no index entry found\n"
        fi
    else
        cd "${basedir}/freedv-rade/freedv-gui" 2>/dev/null && \
            echo -e "\nNOTE: No build record (git: $(git branch --show-current 2>/dev/null || echo HEAD) @ $(git rev-parse --short HEAD 2>/dev/null))\n" || \
            echo -e "\nNOTE: No build record available\n"
        cd "$currdir"
    fi
}

# Main routine ###################
clear
clearvars

cd ~/freedv-rade-build

# Show branch if not main
branch="$(git status|grep 'On branch')"
if [[ $branch =~ "main" ]]; then
    branch=
fi

echo "Wait a moment..."

# Check we have internet and DNS
ping -c3 google.com > /dev/null || { echo "ERROR: Failed to find internet connection or DNS"; exit 1; }

# Do all from user's home folder even if base dir is elsewhere
cd || exit 1

# Check that freedv-rade-build is there
[[ -d freedv-rade-build ]] || { echo -e "ERROR: The freedv-rade-build folder is missing!\nFollow the instructions in the README #at:\nhttps://github.com/barjac/freedv-rade-build\n"; exit 1; }

# Preamble
clear
echo "############### Welcome to freedv-rade-update ################ $branch"
echo -e "\n This script is for maintaining a build of FreeDV RADE \n \
created using freedv-rade-build script.\n"
echo -e "It will optionally:\n \
* Update FreeDV to the latest $default or a specified branch (fast, recommended) \n \
* Fully rebuild FreeDV from scratch (runs freedv-rade-build). \n \
* Create a backup of the current version in use.\n \
* Restore from a previous backup.\n \
* Switch backup with current \n \
* Create a new FreeDV-RADE desktop file.\n \
* Quit the program.\n\n\
************** Nothing will be done until you finally confirm after the summary *************

TIP: Hitting ENTER without typing will automatically select the first option to questions."

# Check if there is already a backup and flag it
[[ -d ${basedir}/freedv-rade_bak ]] && bak=1

echo ""
show_dir_build "Current" "${basedir}/freedv-rade"
[[ -d ${basedir}/freedv-rade_bak ]] && show_dir_build "Backup " "${basedir}/freedv-rade_bak"
echo ""

if grep -q venv < ~/freedv-start; then
    echo "*************************** Your system is using a Python based version of FreeDV RADE."
    echo "*************************** You MUST use the 'Full rebuild' (f) option NOW to update to the new C build."
fi

if (( bak == 1 )); then

    confirm "\nDo you want to (U)pdate, (F)ull re-build, (B)ackup, (R)estore from backup, (S)witch backup/current, Create (D)esktop launcher or (Q)uit?" "[U/F/B/R/S/D/Q]" "Uu" "Ff" "Bb" "Rr" "Ss" "Dd" "Qq"
        case $rval in
            0)
            fastupdt=1
            ;;
            1)
            update=1
            ;;
            2)
            backup=1
            ;;
            3)
            restore=1
            ;;
            4)
            switch=1
            ;;
            5)
            desktop=1
            ;;
            6)
            bye
            ;;
        esac
else
        confirm "\nDo you want to (U)pdate, (F)ull re-build,  (B)ackup, create (D)esktop launcher or (Q)uit?" "[U/F/B/D/Q]" "Uu" "Ff" "Bb" "Dd" "qQ"
        case $rval in
            0)
            fastupdt=1
            ;;
            1)
            update=1
            ;;
            2)
            backup=1
            ;;
            3)
            desktop=1
            ;;
            4)
            bye
            ;;
        esac
fi

prbranches=()
if (( fastupdt == 1 )) && confirm "\n\nUse a specific branch, tag or PR(s)?" "[N/y]" "yY" "nN"; then
    _last_prs_file="/home/${user}/freedv-rade-build/.last-prs"
    _default_input=""

    # Build editable default from previously used PRs/branches (strip pr: prefix)
    if [[ -f "$_last_prs_file" ]] && [[ -s "$_last_prs_file" ]]; then
        while IFS= read -r _line; do
            _line="${_line#pr:}"
            _default_input="${_default_input:+$_default_input }$_line"
        done < "$_last_prs_file"
    fi

    echo -e "\nNOTE: Enter PR numbers and/or a branch name, space-separated."
    [[ -n "$_default_input" ]] && echo "(Edit or clear the previous selection below)"
    if [[ -n "$_default_input" ]]; then
        read -r -e -i "$_default_input" -p "PR(s)/branch: " _input
    else
        read -r -e -p "PR(s)/branch: " _input
    fi

    for entry in $_input; do
        [[ "$entry" =~ ^[0-9]+$ ]] && entry="pr:$entry"
        prbranches+=("$entry")
    done
fi

if (( fastupdt == 1 )) && confirm "\n\nAdd patch(es)?" "[N/y]" "yY" "nN"; then
    patches=()
    _bdir="/home/${user}/freedv-rade-build"
    _last_file="${_bdir}/.last-patches"
    _patch_dir="${_bdir}/patches"

    # Build the list of patches/ subdirectory entries up front (used by both
    # the fresh-pick and edit-list flows below).
    _available=()
    if [[ -d "$_patch_dir" ]]; then
        while IFS= read -r _f; do
            _available+=("$(basename "$_f")")
        done < <(find "$_patch_dir" -maxdepth 1 -name '*.patch' | sort)
    fi

    # Offer to reuse recent patches
    if [[ -f "$_last_file" ]] && [[ -s "$_last_file" ]]; then
        mapfile -t _last_patches < "$_last_file"
        echo -e "\nRecent patches:"
        for _i in "${!_last_patches[@]}"; do
            printf "  %2d) %s\n" "$((_i+1))" "${_last_patches[$_i]#patches/}"
        done
        confirm "(U)se these as-is, (E)dit the list, or start (F)resh?" "[U/E/F]" "Uu" "Ee" "Ff"
        case $? in
            0)
                patches=("${_last_patches[@]}")
                ;;
            1)
                patches=("${_last_patches[@]}")
                echo -e "\nEnter numbers to REMOVE (space-separated, blank for none):"
                read -r _rm
                for _num in $_rm; do
                    if [[ "$_num" =~ ^[0-9]+$ ]] && (( _num >= 1 && _num <= ${#_last_patches[@]} )); then
                        unset 'patches[_num-1]'
                    fi
                done
                patches=("${patches[@]}")

                if (( ${#_available[@]} > 0 )); then
                    echo -e "\nAvailable patches:"
                    for _i in "${!_available[@]}"; do
                        printf "  %2d) %s\n" "$((_i+1))" "${_available[$_i]}"
                    done

                    # Pre-fill with the numbers of patches already kept (so
                    # they're visible and editable on this line too), pulling
                    # them out of `patches` for now -- whatever's left in the
                    # edited line is authoritative for anything with a number.
                    _prefill_nums=()
                    _kept_unmatched=()
                    for _p in "${patches[@]}"; do
                        _pname="$(basename "$_p")"
                        _match=
                        for _i in "${!_available[@]}"; do
                            if [[ "${_available[$_i]}" == "$_pname" ]]; then
                                _prefill_nums+=("$((_i+1))")
                                _match=1
                                break
                            fi
                        done
                        [[ -z "$_match" ]] && _kept_unmatched+=("$_p")
                    done
                    patches=("${_kept_unmatched[@]}")

                    echo -e "Numbers to keep/add (space-separated, blank for none):"
                    read -e -i "${_prefill_nums[*]}" -r _add
                    for _num in $_add; do
                        if [[ "$_num" =~ ^[0-9]+$ ]] && (( _num >= 1 && _num <= ${#_available[@]} )); then
                            _new="patches/${_available[$((_num-1))]}"
                            [[ " ${patches[*]} " == *" $_new "* ]] || patches+=("$_new")
                        fi
                    done

                    if (( ${#_kept_unmatched[@]} > 0 )); then
                        echo -e "\nAlso kept (not found in patches/ listing):"
                        for _p in "${_kept_unmatched[@]}"; do
                            echo "  - $_p"
                        done
                    fi
                fi
                ;;
            *)
                : # start fresh: fall through to the patches/ subdirectory pick below
                ;;
        esac
    fi

    # Pick list from patches/ subdirectory
    if (( ${#patches[@]} == 0 )); then
        if (( ${#_available[@]} > 0 )); then
            echo -e "\nAvailable patches:"
            for _i in "${!_available[@]}"; do
                printf "  %2d) %s\n" "$((_i+1))" "${_available[$_i]}"
            done
            echo -e "Enter numbers (space-separated), or 0 for manual entry:"
            read -r _sel
            echo "Patch numbers entered: $_sel"
            if [[ "$_sel" != "0" ]]; then
                for _num in $_sel; do
                    if [[ "$_num" =~ ^[0-9]+$ ]] && (( _num >= 1 && _num <= ${#_available[@]} )); then
                        patches+=("patches/${_available[$((_num-1))]}")
                    fi
                done
            fi
        fi

        # Manual fallback (if no patches/ dir, empty, or user chose 0)
        if (( ${#patches[@]} == 0 )); then
            echo -e "\n NOTE: Patch files must be in ${_bdir}/ or ${_bdir}/patches/"
            while true; do
                read -rp "Enter a patch filename (or press Enter to finish): " file
                [[ -z "$file" ]] && break
                if [[ ! -f "${_bdir}/$file" ]]; then
                    echo -e "\nERROR: Patch file '$file' not found in ${_bdir}/"
                    if confirm "Continue without this patch?" "[Y/n]" "yY" "nN"; then
                        continue
                    else
                        exit 1
                    fi
                fi
                patches+=("$file")
            done
        fi
    fi
fi

# Auto-detect base commit from per-patch sidecar .commit files
if (( fastupdt == 1 )) && (( ${#patches[@]} > 0 )); then
    for _p in "${patches[@]}"; do
        _sidecar="/home/${user}/freedv-rade-build/${_p%.patch}.commit"
        if [[ -f "$_sidecar" ]]; then
            _sc=$(tr -d '[:space:]' < "$_sidecar")
            echo -e "\nPatch $(basename "$_p") is using base commit $_sc."
            cname="$_sc"
            break
        fi
    done
fi

# Ask about a specific commit (skipped if a patch sidecar already set one)
if (( fastupdt == 1 )) && [[ -z "$cname" ]] && confirm "\n\nUse a specific commit?" "[N/y]" "yY" "nN"; then
    read -r -p "Enter the commit git#:" cname
fi

if ( (( fastupdt == 1 )) || (( update == 1 )) || (( backup = 1 )) ) && (( desktop != 1 )) && (( bak != 1 )) && (( restore != 1 )) && (( switch != 1 )); then
# Ask to backup with the current version
    echo -e "\nYou currently have no backup of FreeDV-RADE."
    if confirm "\nCreate a backup of the current version?" "[N/y]" "Yy" "Nn"; then
         backup=1
        # Check we have space
        (( $(df -hBG --output=avail $basedir |tr '\n' ' '|tr -s ' '|xargs|cut -d ' ' -f2|cut -dG -f1) > 3 )) || { echo -e "\nInsufficient disk space for backup"; backup=0; }
    fi
fi

if (( bak == 1 )) && (( restore != 1 )) && (( desktop != 1 )) && (( switch != 1 )); then
    echo -e "\nYou already have a backup of a previous FreeDV build."
    if confirm "Replace the current backup with a new one of the current version?" "[N/y]" "Yy" "Nn"; then
        backup=1
        overwrite=1
    else
        backup=0
    fi
fi

# Debug
#echo "U=$fastupdt F=$update B=$backup R=$restore S=$switch D=$desktop prbranches=${prbranches[*]}"
# Summary of what will be done
if (( fastupdt == 1 )) || (( update == 1 )) || (( backup == 1 )) || (( restore == 1 )) || (( desktop == 1 )) || (( switch == 1 )); then
    echo -e "\n\nSummary of selected tasks:"
    echo -e "###########################\n"
    if (( backup == 1 )) ; then
        if (( bak == 1 )); then 
            if (( overwrite == 1 )); then
                echo "A new backup will be created overwriting the old backup."
            else
                echo "A new backup will be created."
            fi
        else
            echo "A backup will be created."
        fi
    fi

    if (( fastupdt == 1 )); then
        if (( ${#prbranches[@]} == 0 )); then
            updt_str="built at $default"
        else
            _preview_base="$default"
            _preview_prs=()
            for _entry in "${prbranches[@]}"; do
                if [[ "$_entry" == pr:* ]]; then
                    _preview_prs+=("${_entry#pr:}")
                else
                    _preview_base="$_entry"
                fi
            done
            if (( ${#_preview_prs[@]} == 0 )); then
                updt_str="built at $_preview_base"
            else
                updt_str="built at $_preview_base with PR(s) ${_preview_prs[*]} merged"
            fi
        fi

        if (( ${#cname} > 0 )); then
            updt_str="$updt_str at commit $cname"
        fi

        if (( ${#patches[@]} > 0 )); then
            updt_str="$updt_str and patched with ${patches[@]}"
        fi
        echo "FreeDV will be $updt_str"
    fi

    if (( update == 1 )); then 
        echo "FreeDV will be fully re-built from latest $default"
    fi

    if (( restore == 1 )); then
        echo -e "FreeDV will be restored from your current backup which will remain in place.\nThis will overwrite your current version."
    fi

    if (( switch == 1 )); then
        echo -e "The current version will be switched with the one in backup and vice versa:"
        show_dir_build "Current" "${basedir}/freedv-rade"
        show_dir_build "Backup " "${basedir}/freedv-rade_bak"
    fi

    if (( desktop == 1 )); then
        echo -e "A new FreeDV-RADE desktop file (Icon) will be added to your desktop unless\n \
 a file named 'Freedv-RADE.desktop already exists (maybe re-name it?)."
    fi

    if confirm "\nPerform the selected tasks?" "[Y/n]" "Yy" "Nn"; then

# Create backup
        if (( backup == 1)); then
            echo -e "\nCreating backup..."
            rm -rf ${basedir}/freedv-rade_bak/
            if cp -rf ${basedir}/freedv-rade/ ${basedir}/freedv-rade_bak; then
                echo "Backup complete."
            else
                echo "Backup failed."
                exit 1
            fi
        fi

# Fast update
        if (( fastupdt == 1 )); then
            if (( ${#prbranches[@]} > 1 )); then
                echo -e "\nStarting fast update in 3 seconds combining PRs: ${prbranches[*]}."
            elif (( ${#prbranches[@]} == 1 )); then
                echo -e "\nStarting fast update in 3 seconds to ${prbranches[0]}."
            else
                echo -e "\nStarting fast update in 3 seconds to latest $default."
            fi
            sleep 3
            if fastupdt; then
                echo "Update complete"
            else
                echo "Update failed"
                exit 1
            fi
        fi

# Restore from backup
        if (( restore == 1 )); then
            echo -e "\nRestoring from backup..."
            if (rm -rf ${basedir}/freedv-rade/ && cp -rf ${basedir}/freedv-rade_bak/ ${basedir}/freedv-rade); then
                echo "Restore complete."
            else
                echo "Restore failed."
                exit 1
            fi
        fi

# Switch backup with current
		if (( switch == 1 )); then
			echo -e "\nSwitching backup with current..."
			[[ -d ${basedir}/freedv-rade_tmp ]] && rm -fr ${basedir}/freedv-rade_tmp

			mv ${basedir}/freedv-rade ${basedir}/freedv-rade_tmp || { echo "Failed to move freedv-rade to freedv-rade_tmp"; exit 1; }
			mv ${basedir}/freedv-rade_bak ${basedir}/freedv-rade || { echo "Failed to move freedv-rade_bak to freedv-rade"; exit 1; }
			mv ${basedir}/freedv-rade_tmp ${basedir}/freedv-rade_bak ||{ echo "Failed to move freedv-rade_tmp to freedv-rade_bak"; exit 1; }
			echo -e "\nDone :)\n"
		fi

# Full re-build
        if (( update == 1 )); then 
            echo -e "\nStarting full rebuild in 3 seconds. Please be patient this will take some time ..."
            sleep 3
            if freedv-rade-build/freedv-rade-build; then
                echo "Full rebuild complete"
                _commit=$(git -C "${basedir}/freedv-rade/freedv-gui" rev-parse --short HEAD 2>/dev/null || echo "unknown")
                write_build_index "${default} @ ${_commit}"
            else
                echo "Full rebuild failed"
                exit 1
            fi
        fi
# Desktop file
        if (( desktop == 1 )); then
            freedv-rade-build/mk-desktop
        fi

        if grep -q venv < ~/freedv-start; then
            echo -e "Your ~/freedv-start script has been edited to work without Python \n\
                 and a backup of the original has been saved as freedv-start.pybak. \n\
                 Any other custom start scripts will need to be modified in a similar fashion. \n"
            sed -i.pybak \
                -e '/PYTHONPATH.*src\/freedv/ s/.*/src\/freedv $@/' \
                -e '/venv\|deactivate\|python\|PYTHONPATH\|environment/Id' ~/freedv-start
        fi
    fi
else
    bye
fi
read -r -s -n 1 -p $'\nPress any key to exit...'
echo
bye
