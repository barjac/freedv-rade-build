+#if defined(__WXGTK__) && defined(HAS_GTK3)
+    // See SettlePositionContext_ for why this needs both handlers.
+    // (The context is built as its own statement, not inline in the
+    // g_signal_connect() call -- g_signal_connect is a macro, and the
+    // preprocessor splits macro arguments on commas that aren't inside
