+    auto* settleContext = new SettlePositionContext_{this, x, y, 10};
+    g_signal_connect(
+        GTK_WIDGET(GetHandle()), "map-event",
+        G_CALLBACK(OnFrameMapEvent_), settleContext);
+    g_signal_connect(
+        GTK_WIDGET(GetHandle()), "configure-event",
+        G_CALLBACK(OnFrameConfigureEvent_), settleContext);
+#else
+    // XXX - Some window managers apply stricter "initial placement"
+    // constraints to a not-yet-mapped window than to one that's already on
+    // screen -- notably, they may refuse to honor a requested position that
+    // would place the (still invisible, undecorated) top edge flush with the
+    // screen's top edge, silently recentering the window instead. Deferring
+    // the Move() until after the frame is shown (mirroring the resize
+    // workaround below) makes the window manager treat it as a user-initiated
+    // move, which is honored literally.
+    CallAfter([=]()
