+// Restores the saved main window position, fighting off the window
+// manager's own initial-placement policy if necessary.
+//
+// This isn't a timing race that can be won by moving earlier or later --
+// instrumented logging (KWin on Plasma 6/Wayland+XWayland) showed the
+// window *does* move to the saved position immediately when asked, but the
+// WM then applies its own "smart" placement (e.g. centered) to the window
+// asynchronously, ~350ms after mapping, unconditionally overriding whatever
+// the client requested. So instead of trying to out-race it, this watches
+// every subsequent configure-event (geometry change) and, if the WM has
+// knocked the window off the target position, simply re-issues Move() to
+// put it back. It gives up after a handful of attempts or once the position
+// matches, so it won't fight the user's own later repositioning.
+struct SettlePositionContext_
+{
+    wxFrame* frame;
+    int targetX;
+    int targetY;
+    int attemptsLeft;
+};
+
+static gboolean OnFrameConfigureEvent_(GtkWidget* widget, GdkEventConfigure*, gpointer userData)
+{
+    auto* ctx = static_cast<SettlePositionContext_*>(userData);
+    wxPoint pos = ctx->frame->GetPosition();
+    log_info("DIAG: configure-event, wx position (%d, %d), target (%d, %d), %d attempts left",
+        pos.x, pos.y, ctx->targetX, ctx->targetY, ctx->attemptsLeft);
+
+    if ((pos.x == ctx->targetX && pos.y == ctx->targetY) || ctx->attemptsLeft <= 0)
+    {
+        g_signal_handlers_disconnect_by_func(widget, (gpointer)OnFrameConfigureEvent_, userData);
+        delete ctx;
+        return FALSE;
+    }
+
+    ctx->attemptsLeft--;
+    ctx->frame->Move(ctx->targetX, ctx->targetY);
+    return FALSE;
+}
+
+static gboolean OnFrameMapEvent_(GtkWidget* widget, GdkEventAny*, gpointer userData)
+{
+    auto* ctx = static_cast<SettlePositionContext_*>(userData);
+    ctx->frame->Move(ctx->targetX, ctx->targetY);
+
+    // Only the first map (initial startup) should apply the saved position --
+    // later maps, e.g. un-minimizing, should leave the window where the user
+    // last put it.
+    g_signal_handlers_disconnect_by_func(widget, (gpointer)OnFrameMapEvent_, userData);
+    return FALSE;
+}
