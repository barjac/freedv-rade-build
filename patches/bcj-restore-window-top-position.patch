+
+// Applies the saved main window position once the underlying GTK window has
+// actually been mapped by the window manager. CallAfter()/idle-time deferral
+// isn't good enough here: it only guarantees "runs on a later iteration of
+// the event loop", not "runs after the WM has finished placing the window",
+// and on slower machines the two can drift apart. When that race is lost, a
+// window manager (observed with KWin on Plasma 6/Wayland+XWayland, plausibly
+// others) treats the Move() as part of *initial* placement rather than a
+// later user-driven move, and falls back to its default placement policy
+// (e.g. centered) instead of honoring the requested coordinates. Binding to
+// "map-event" removes the race entirely.
+struct MoveOnMapContext_
+{
+    wxFrame* frame;
+    int x;
+    int y;
+};
+
+static gboolean OnFrameMapEvent_(GtkWidget* widget, GdkEventAny*, gpointer userData)
+{
+    auto* ctx = static_cast<MoveOnMapContext_*>(userData);
+    log_info("DIAG: map-event fired, moving to (%d, %d)", ctx->x, ctx->y);
+    ctx->frame->Move(ctx->x, ctx->y);
+    wxPoint immediatePos = ctx->frame->GetPosition();
+    log_info("DIAG: position immediately after Move(): (%d, %d)", immediatePos.x, immediatePos.y);
+
+    auto* posCheckTimer = new wxTimer();
+    wxFrame* frame = ctx->frame;
+    posCheckTimer->Bind(wxEVT_TIMER, [frame](wxTimerEvent&) {
+        wxPoint pos = frame->GetPosition();
+        log_info("DIAG: position 1500ms after map-event: (%d, %d)", pos.x, pos.y);
+    });
+    posCheckTimer->StartOnce(1500);
+
+    // Only the first map (initial startup) should apply the saved position --
+    // later maps, e.g. un-minimizing, should leave the window where the user
+    // last put it.
+    g_signal_handlers_disconnect_by_func(widget, (gpointer)OnFrameMapEvent_, userData);
+    delete ctx;
+    return FALSE;
+}
