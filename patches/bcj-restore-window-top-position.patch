+#if defined(__WXGTK__) && defined(HAS_GTK3)
+    // See OnFrameMapEvent_ for why this doesn't just use CallAfter().
+    // (The context is built as its own statement, not inline in the
+    // g_signal_connect() call -- g_signal_connect is a macro, and the
+    // preprocessor splits macro arguments on commas that aren't inside
+    // parentheses; braces don't protect them, so a brace-init here would
+    // silently mis-split the macro's argument list.)
+    log_info("DIAG: connecting map-event handler, target position (%d, %d)", x, y);
+    auto* moveOnMapContext = new MoveOnMapContext_{this, x, y};
+    g_signal_connect(
+        GTK_WIDGET(GetHandle()), "map-event",
+        G_CALLBACK(OnFrameMapEvent_), moveOnMapContext);
+#else
+    // XXX - Some window managers apply stricter "initial placement"
+    // constraints to a not-yet-mapped window than to one that's already on
+    // screen -- notably, they may refuse to honor a requested position that
+    // would place the (still invisible, undecorated) top edge flush with the
+    // screen's top edge, silently recentering the window instead. Deferring
+    // the Move() until after the frame is shown (mirroring the resize
+    // workaround below) makes the window manager treat it as a user-initiated
+    // move, which is honored literally.
+    CallAfter([=]()
+    {
+        Move(x, y);
+    });
+#endif // defined(__WXGTK__) && defined(HAS_GTK3)
