diff --git a/src/gui/util/WindowPositionRestore.cpp b/src/gui/util/WindowPositionRestore.cpp
new file mode 100644
index 00000000..46bddbfa
--- /dev/null
+++ b/src/gui/util/WindowPositionRestore.cpp
@@ -0,0 +1,79 @@
+#include "WindowPositionRestore.h"
+
+#include <wx/frame.h>
+#include "util/logging/ulog.h"
+
+#if defined(__WXGTK__) && defined(HAS_GTK3)
+#include <gtk/gtk.h>
+
+namespace
+{
+
+struct SettlePositionContext_
+{
+    wxFrame* frame;
+    int targetX;
+    int targetY;
+    int attemptsLeft;
+};
+
+gboolean OnFrameConfigureEvent_(GtkWidget* widget, GdkEventConfigure*, gpointer userData)
+{
+    auto* ctx = static_cast<SettlePositionContext_*>(userData);
+    wxPoint pos = ctx->frame->GetPosition();
+
+    if ((pos.x == ctx->targetX && pos.y == ctx->targetY) || ctx->attemptsLeft <= 0)
+    {
+        log_info("DIAG: RestoreWindowPosition settled for frame %p at (%d, %d), target was (%d, %d), %d attempts remained",
+            (void*)ctx->frame, pos.x, pos.y, ctx->targetX, ctx->targetY, ctx->attemptsLeft);
+        g_signal_handlers_disconnect_by_func(widget, (gpointer)OnFrameConfigureEvent_, userData);
+        delete ctx;
+        return FALSE;
+    }
+
+    ctx->attemptsLeft--;
+    log_info("DIAG: RestoreWindowPosition re-asserting for frame %p, was (%d, %d), moving to (%d, %d), %d attempts left",
+        (void*)ctx->frame, pos.x, pos.y, ctx->targetX, ctx->targetY, ctx->attemptsLeft);
+    ctx->frame->Move(ctx->targetX, ctx->targetY);
+    return FALSE;
+}
+
+gboolean OnFrameMapEvent_(GtkWidget* widget, GdkEventAny*, gpointer userData)
+{
+    auto* ctx = static_cast<SettlePositionContext_*>(userData);
+    log_info("DIAG: RestoreWindowPosition map-event for frame %p, moving to (%d, %d)",
+        (void*)ctx->frame, ctx->targetX, ctx->targetY);
+    ctx->frame->Move(ctx->targetX, ctx->targetY);
+
+    // Only the first map (initial startup) should apply the saved position --
+    // later maps, e.g. un-minimizing, should leave the window where the user
+    // last put it.
+    g_signal_handlers_disconnect_by_func(widget, (gpointer)OnFrameMapEvent_, userData);
+    return FALSE;
+}
+
+} // namespace
+
+void RestoreWindowPosition(wxFrame* frame, int x, int y)
+{
+    log_info("DIAG: RestoreWindowPosition called for frame %p, target (%d, %d)", (void*)frame, x, y);
+    auto* settleContext = new SettlePositionContext_{frame, x, y, 10};
+    g_signal_connect(
+        GTK_WIDGET(frame->GetHandle()), "map-event",
+        G_CALLBACK(OnFrameMapEvent_), settleContext);
+    g_signal_connect(
+        GTK_WIDGET(frame->GetHandle()), "configure-event",
+        G_CALLBACK(OnFrameConfigureEvent_), settleContext);
+}
+
+#else
+
+void RestoreWindowPosition(wxFrame* frame, int x, int y)
+{
+    frame->CallAfter([frame, x, y]()
+    {
+        frame->Move(x, y);
+    });
+}
+
+#endif // defined(__WXGTK__) && defined(HAS_GTK3)
diff --git a/src/gui/util/WindowPositionRestore.h b/src/gui/util/WindowPositionRestore.h
new file mode 100644
index 00000000..ffe51c50
--- /dev/null
+++ b/src/gui/util/WindowPositionRestore.h
@@ -0,0 +1,16 @@
+#pragma once
+
+class wxFrame;
+
+// Restores a top-level frame's position from saved configuration.
+//
+// Must be called before the frame is shown. On Linux/GTK3, some window
+// managers (observed: KWin on Plasma 6) apply their own asynchronous
+// initial-placement policy shortly after the window is mapped, silently
+// overriding whatever position the client already set -- no matter how
+// early or late the client's own move happens. This watches for that and
+// re-asserts the requested position if the WM knocks it off, giving up
+// after a handful of attempts (or once the position matches) so it won't
+// fight the user's own later repositioning. On other platforms this is
+// just a straightforward deferred move.
+void RestoreWindowPosition(wxFrame* frame, int x, int y);
