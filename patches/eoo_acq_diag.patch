diff --git a/cmake/BuildRADE.cmake b/cmake/BuildRADE.cmake
--- a/cmake/BuildRADE.cmake
+++ b/cmake/BuildRADE.cmake
@@ -19,4 +19,56 @@
    INSTALL_COMMAND ""
 )

+# Write the EOO acquisition diagnostic patcher at cmake configure time.
+# The ExternalProject step below runs it at build time against the fetched RADE source.
+file(WRITE "${CMAKE_BINARY_DIR}/eoo_acq_diag.py" [[
+import sys
+src = sys.argv[1]
+def patch(fname, old, new, guard):
+    c = open(fname).read()
+    if guard not in c:
+        c = c.replace(old, new)
+        open(fname, 'w').write(c)
+        print('eoo_acq_diag: patched', fname)
+patch(src+'/src/rade_acq.h',
+      '    float Dtmax12_eoo;\n    int f_ind_max;',
+      '    float Dtmax12_eoo;\n    float Dthresh_eoo;\n    float Dt1_eoo_abs;\n    float Dt2_eoo_abs;\n    int f_ind_max;',
+      'Dthresh_eoo')
+patch(src+'/src/rade_acq.c',
+      '    acq->Dtmax12_eoo = Dtmax12_eoo;\n\n    *valid',
+      '    acq->Dtmax12_eoo = Dtmax12_eoo;\n    acq->Dthresh_eoo = Dthresh_eoo;\n    acq->Dt1_eoo_abs = rade_cabs(Dt1_eoo);\n    acq->Dt2_eoo_abs = rade_cabs(Dt2_eoo);\n\n    *valid',
+      'acq->Dthresh_eoo')
+patch(src+'/src/rade_rx.c',
+      '"Dtmax12: %8.2f %8.2f tmax: %4d fmax: %6.2f"',
+      '"Dtmax12: %8.2f %8.2f(%.2f+%.2f/%.2f) tmax: %4d fmax: %6.2f"',
+      'Dt1_eoo_abs')
+patch(src+'/src/rade_rx.c',
+      'rx->acq.Dtmax12, rx->acq.Dtmax12_eoo, rx->tmax, rx->fmax',
+      'rx->acq.Dtmax12, rx->acq.Dtmax12_eoo, rx->acq.Dt1_eoo_abs, rx->acq.Dt2_eoo_abs, rx->acq.Dthresh_eoo, rx->tmax, rx->fmax',
+      'Dt1_eoo_abs')
+patch(src+'/src/rade_acq.h',
+      '    float Dt2_eoo_abs;\n    int f_ind_max;',
+      '    float Dt2_eoo_abs;\n    float pwr_eoo1;\n    float pwr_eoo2;\n    int f_ind_max;',
+      'pwr_eoo1')
+patch(src+'/src/rade_acq.c',
+      '    acq->Dt2_eoo_abs = rade_cabs(Dt2_eoo);\n\n    *valid',
+      '    acq->Dt2_eoo_abs = rade_cabs(Dt2_eoo);\n    {int _n;float _p1=0.0f,_p2=0.0f;for(_n=0;_n<M;_n++){RADE_COMP _s1=rx[tmax+M+Ncp+_n];RADE_COMP _s2=rx[tmax+Nmf+_n];_p1+=_s1.real*_s1.real+_s1.imag*_s1.imag;_p2+=_s2.real*_s2.real+_s2.imag*_s2.imag;}acq->pwr_eoo1=_p1/M;acq->pwr_eoo2=_p2/M;}\n\n    *valid',
+      'pwr_eoo1')
+patch(src+'/src/rade_rx.c',
+      '"Dtmax12: %8.2f %8.2f(%.2f+%.2f/%.2f) tmax: %4d fmax: %6.2f"',
+      '"Dtmax12: %8.2f %8.2f(%.2f+%.2f/%.2f) p1=%.6f p2=%.6f tmax: %4d fmax: %6.2f"',
+      'p1=%.6f')
+patch(src+'/src/rade_rx.c',
+      'rx->acq.Dt1_eoo_abs, rx->acq.Dt2_eoo_abs, rx->acq.Dthresh_eoo, rx->tmax, rx->fmax',
+      'rx->acq.Dt1_eoo_abs, rx->acq.Dt2_eoo_abs, rx->acq.Dthresh_eoo, rx->acq.pwr_eoo1, rx->acq.pwr_eoo2, rx->tmax, rx->fmax',
+      'pwr_eoo1')
+]])
+
+ExternalProject_Add_Step(build_rade eoo_acq_diag
+    COMMAND python3 "${CMAKE_BINARY_DIR}/eoo_acq_diag.py" <SOURCE_DIR>
+    DEPENDEES update
+    DEPENDERS build
+    ALWAYS 1
+)
+
 ExternalProject_Get_Property(build_rade BINARY_DIR)
