+
+#include <algorithm>
+#include <cassert>
+#include <cmath>
+
+#include "BeepStep.h"
+
+#ifndef M_PI
+    #define M_PI 3.1415926535897932384626433832795
+#endif
+
+BeepStep::BeepStep(int sampleRate, int frequency, std::initializer_list<BeepSegment> pattern,
+                   realtime_fp<void(BeepStep&)> const& onCompleteFn)
+    : sampleRate_(sampleRate)
+    , onCompleteFn_(onCompleteFn)
+    , sampleCtr_(0)
+    , pendingReset_(false)
+{
+    int totalSamples = 0;
+    for (auto& seg : pattern)
+        totalSamples += (sampleRate * seg.durationMs) / 1000;
+
+    samplesToGenerate_ = totalSamples;
+    globalRampSamples_ = (sampleRate * 5) / 1000;
+    pregenSamples_ = std::make_unique<short[]>(totalSamples);
+    execOutput_ = std::make_unique<short[]>(sampleRate); // sized for up to 1s per execute() call
+
+    // 5ms raised-cosine (Hann) attack/release on each tone segment to avoid hard clicks.
+    const int rampSamples = globalRampSamples_;
+    constexpr int TONE_AMPLITUDE = 8192;
+    double phase = 0.0;
+    int idx = 0;
+
+    for (auto& seg : pattern) {
+        int segSamples = (sampleRate * seg.durationMs) / 1000;
+        int ramp = std::min(rampSamples, segSamples / 2);
+
+        for (int i = 0; i < segSamples; i++) {
+            if (seg.isTone) {
+                double env = 1.0;
+                if (i < ramp)
+                    env = 0.5 * (1.0 - std::cos(M_PI * i / ramp));
+                else if (i >= segSamples - ramp)
+                    env = 0.5 * (1.0 + std::cos(M_PI * (i - (segSamples - ramp)) / ramp));
+                pregenSamples_[idx] = static_cast<short>(TONE_AMPLITUDE * env * std::cos(phase));
+            } else {
+                pregenSamples_[idx] = 0;
+            }
+            // Advance phase even during gaps so the next tone resumes at a continuous phase.
+            phase += 2.0 * M_PI * frequency / sampleRate;
+            idx++;
+        }
+    }
+
+    assert(idx == totalSamples);
+}
+
+BeepStep::~BeepStep()
+{
+    // empty
+}
+
+int BeepStep::getInputSampleRate() const FREEDV_NONBLOCKING
+{
+    return sampleRate_;
+}
+
+int BeepStep::getOutputSampleRate() const FREEDV_NONBLOCKING
+{
+    return sampleRate_;
+}
+
+short* BeepStep::execute(short* inputSamples, int numInputSamples, int* numOutputSamples) FREEDV_NONBLOCKING
+{
+    // Apply a deferred reset at the entry point so it never triggers a mid-buffer restart.
+    if (pendingReset_)
+    {
+        sampleCtr_ = 0;
+        pendingReset_ = false;
+    }
+
+    *numOutputSamples = numInputSamples;
+
+    bool completed = false;
+    for (int index = 0; index < numInputSamples; index++)
+    {
+        if (sampleCtr_ < samplesToGenerate_)
+        {
+            short outSample;
+
+            if (sampleCtr_ < globalRampSamples_)
+            {
+                // Mute pre-roll: fade the live input to silence before the beep
+                // starts. At sampleCtr_=0 output equals input[0], continuous with
+                // the bypass path, so there is no click at the buffer boundary.
+                int scale = 32767 - sampleCtr_ * 32767 / globalRampSamples_;
+                outSample = static_cast<short>((int)inputSamples[index] * scale / 32767);
+            }
+            else if (sampleCtr_ >= samplesToGenerate_ - globalRampSamples_)
+            {
+                // Mute post-roll: fade the live input back in from silence so the
+                // handoff back to the bypass path is seamless.
+                int scale = (sampleCtr_ - (samplesToGenerate_ - globalRampSamples_))
+                            * 32767 / globalRampSamples_;
+                outSample = static_cast<short>((int)inputSamples[index] * scale / 32767);
+            }
+            else
+            {
+                outSample = pregenSamples_[sampleCtr_];
+            }
+
+            execOutput_[index] = outSample;
+            sampleCtr_++;
+        }
+        else
+        {
+            execOutput_[index] = inputSamples[index];
+            if (!completed)
+            {
+                completed = true;
+                onCompleteFn_(*this); // sets g_totBeepActive=false; calls reset() -> pendingReset_=true
+            }
+        }
+    }
+
+    return execOutput_.get();
+}
+
+void BeepStep::reset() FREEDV_NONBLOCKING
+{
+    // Defer the actual reset to the next execute() entry so we never restart
+    // mid-buffer when called from within onCompleteFn_.
+    pendingReset_ = true;
+}
