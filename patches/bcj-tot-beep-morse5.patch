From 134b4092a733f8c76b9fe76f9eb5b249099570e1 Mon Sep 17 00:00:00 2001
From: Barry Jackson <barjac@mageia.org>
Date: Sun, 7 Jun 2026 22:27:29 +0100
Subject: [PATCH 6/7] Bypass RADE decoder during TOT beep to fix timing
 corruption (S+I instead of '5')
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

RADE's pipeline step outputs 0 samples on most calls (it accumulates modem
input until a full FARGAN frame is ready, then bursts). BeepStep's
sample-counter advances only when it receives non-zero input, so when placed
downstream of RADE the beep timing is corrupted — producing audible effects
like 'S+I' (3+2 dits) instead of the correct '5' (5 dits), varying on each
activation.

Fix: add g_totBeepActive || s_totBeepPlaying to the eitherOrRfDemodulationStep
bypass condition. While the beep is active the pipeline skips RADE entirely,
giving BeepStep regular 960-sample buffers from the (near-silent during TX)
raw radio input. The existing 5ms pre-roll in BeepStep fades that silence
cleanly to zero at the start of playback.

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 src/pipeline/TxRxThread.cpp | 11 +++++++++--
 1 file changed, 9 insertions(+), 2 deletions(-)

diff --git a/src/pipeline/TxRxThread.cpp b/src/pipeline/TxRxThread.cpp
index 87b377bb..c031ee43 100644
--- a/src/pipeline/TxRxThread.cpp
+++ b/src/pipeline/TxRxThread.cpp
@@ -493,14 +493,21 @@ void TxRxThread::initializePipeline_()
                         (g_recVoiceKeyerFile) ||
                         (g_voice_keyer_tx.load(std::memory_order_acquire) && NonblockingWxGetApp().appConfiguration.monitorVoiceKeyerAudio.getWithoutProcessing()) ||
                         (g_tx.load(std::memory_order_acquire) && NonblockingWxGetApp().appConfiguration.monitorTxAudio.getWithoutProcessing())
-                    ); },
+                    ) ||
+                    // Bypass RADE during TOT beep so BeepStep gets regular-sized buffers.
+                    // RADE outputs 0 samples on most calls (accumulates input until a full frame
+                    // is ready), which would corrupt BeepStep's sample-counter-based timing.
+                    g_totBeepActive.load(std::memory_order_acquire) ||
+                    s_totBeepPlaying.load(std::memory_order_acquire); },
                 bypassRfDemodulationPipeline,
                 rfDemodulationPipeline);
         }
         else
         {
             eitherOrRfDemodulationStep = new EitherOrStep(
-                +[]() FREEDV_NONBLOCKING { return g_analog != 0; },
+                +[]() FREEDV_NONBLOCKING { return g_analog != 0 ||
+                    g_totBeepActive.load(std::memory_order_acquire) ||
+                    s_totBeepPlaying.load(std::memory_order_acquire); },
                 bypassRfDemodulationPipeline,
                 rfDemodulationPipeline);
         }
