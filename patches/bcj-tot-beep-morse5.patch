From b9f42b5367b32418d4dc841d9a4dc1ccb17f63c1 Mon Sep 17 00:00:00 2001
From: Barry Jackson <barjac@mageia.org>
Date: Sun, 7 Jun 2026 23:40:40 +0100
Subject: [PATCH 7/7] Remove pre/post-roll from BeepStep to eliminate crunches
 on raw audio input
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

The pre/post-roll faded the live pipeline input in/out around the beep.
This was designed for decoded speech (low level), but after the RADE bypass
fix the input is raw radio RX audio, which can be high level during TX.
The pre-roll started at full-scale input amplitude, producing an audible
crunch at the start of each beep activation.

The fix is simply to remove the pre/post-roll entirely. The pregenSamples_
pattern already includes 10ms of silence at both ends, and each tone segment
already has a 5ms Hann attack/release envelope — no other transitions exist
that need smoothing. globalRampSamples_ is no longer a member; the ramp size
is used only as a local during pattern pre-generation.

Co-Authored-By: Claude Sonnet 4.6 <noreply@anthropic.com>
---
 src/pipeline/BeepStep.cpp | 19 ++-----------------
 src/pipeline/BeepStep.h   |  1 -
 2 files changed, 2 insertions(+), 18 deletions(-)

diff --git a/src/pipeline/BeepStep.cpp b/src/pipeline/BeepStep.cpp
index 8249dc4b..28e0f404 100644
--- a/src/pipeline/BeepStep.cpp
+++ b/src/pipeline/BeepStep.cpp
@@ -12,7 +12,6 @@ BeepStep::BeepStep(int sampleRate, int frequency,
     , isActiveFn_(isActiveFn)
     , onCompleteFn_(onCompleteFn)
     , samplesToGenerate_(0)
-    , globalRampSamples_((sampleRate * 5) / 1000)
     , sampleCtr_(0)
     , playing_(false)
 {
@@ -23,7 +22,7 @@ BeepStep::BeepStep(int sampleRate, int frequency,
     pregenSamples_ = std::make_unique<short[]>(samplesToGenerate_);
     execOutput_    = std::make_unique<short[]>(samplesToGenerate_);
 
-    int ramp = globalRampSamples_;
+    int ramp = (sampleRate * 5) / 1000;
     double phase = 0.0;
     double phaseStep = M_2PI * frequency / sampleRate;
     int idx = 0;
@@ -70,21 +69,7 @@ short* BeepStep::execute(short* inputSamples, int numInputSamples, int* numOutpu
         short outSample;
 
         if (playing_ && sampleCtr_ < samplesToGenerate_) {
-            // Mute pre-roll: fade live input to silence over first 5ms
-            if (sampleCtr_ < globalRampSamples_) {
-                int scale = 32767 - sampleCtr_ * 32767 / globalRampSamples_;
-                outSample = static_cast<short>((int)inputSamples[index] * scale / 32767);
-            }
-            // Mute post-roll: fade live input back in over last 5ms
-            else if (sampleCtr_ >= samplesToGenerate_ - globalRampSamples_) {
-                int scale = (sampleCtr_ - (samplesToGenerate_ - globalRampSamples_)) * 32767 / globalRampSamples_;
-                outSample = static_cast<short>((int)inputSamples[index] * scale / 32767);
-            }
-            // Pure pre-generated beep
-            else {
-                outSample = pregenSamples_[sampleCtr_];
-            }
-            sampleCtr_++;
+            outSample = pregenSamples_[sampleCtr_++];
         } else if (playing_) {
             // Pattern complete — passthrough + fire callback once
             outSample = inputSamples[index];
diff --git a/src/pipeline/BeepStep.h b/src/pipeline/BeepStep.h
index 1f5bd16a..6949a3b6 100644
--- a/src/pipeline/BeepStep.h
+++ b/src/pipeline/BeepStep.h
@@ -29,7 +29,6 @@ private:
     realtime_fp<bool()> isActiveFn_;
     realtime_fp<void(BeepStep&)> onCompleteFn_;
     int samplesToGenerate_;
-    int globalRampSamples_;
     int sampleCtr_;
     bool playing_;
     std::unique_ptr<short[]> pregenSamples_;
