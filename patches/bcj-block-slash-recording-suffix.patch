+void BeginRecordingDialog::OnRecordingSuffixChar(wxKeyEvent& event)
+{
+    // Block manual entry of '/', as it isn't valid in a filename suffix.
+    if (event.GetKeyCode() == '/')
+    {
+        return;
+    }
+
+    event.Skip();
+}
